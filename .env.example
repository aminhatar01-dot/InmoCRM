# === InmoCRM — Variables de Entorno ===
# Copiar este archivo a .env y completar los valores

# Gemini AI (requerido para generación de copy de marketing)
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# URL pública de la app (autoinjectada por AI Studio / Cloud Run)
APP_URL="MY_APP_URL"

# === Nodemailer SMTP (notificaciones por email) ===
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER="aminhatar01@gmail.com"
SMTP_PASS=""
AGENT_NOTIFICATION_EMAIL="aminhatar01@gmail.com"

# === Mercado Pago (suscripciones) ===
MERCADOPAGO_ACCESS_TOKEN=""

# === Google Maps (opcional — si se usa @vis.gl/react-google-maps) ===
# VITE_GOOGLE_MAPS_API_KEY=""

# === Firebase ===
# Configurado via firebase-applet-config.json (auto-generado por AI Studio)
# No requiere variables de entorno adicionales
